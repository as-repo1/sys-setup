# This file was created by fish when upgrading to version 4.3, to migrate
# theme variables from universal to global scope.
# Don't edit this file, as it will be written by the web-config tool (`fish_config`).
# To customize your theme, delete this file and see
#     help interactive#syntax-highlighting
# or
#     man fish-interactive | less +/^SYNTAX.HIGHLIGHTING
# for appropriate commands to add to ~/.config/fish/config.fish instead.
# See also the release notes for fish 4.3.0 (run `help relnotes`).

set --global fish_color_command '#81A1C1'
set --global fish_color_comment '#4C566A'
set --global fish_color_error '#E06C75' --bold
set --global fish_color_operator '#D08770'
set --global fish_color_param '#A3BE8C'
set --global fish_color_quote '#88C0D0'
